#version 330 core

// location gets set in VertexArray: glVertexAttribPointer
layout (location = 0) in vec2 position;
layout (location = 1) in vec4 color;

// send color to fragment.
out vec4 v_color;

uniform mat4 u_MVP;

void main()
{
    v_color = color;
    gl_Position = u_MVP * vec4(position, 0.0, 1.0);
}
